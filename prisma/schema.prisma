generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  fullName      String
  email         String    @unique
  phone         String?
  passwordHash  String
  role          String    @default("CLIENT") // CLIENT, PROVIDER, ADMIN
  isBanned      Boolean   @default(false)
  profilePicture String?  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  providerProfile ProviderProfile?
  bookingsAsClient Booking[]       @relation("ClientBookings")
  notifications   Notification[]
  messages        SupportMessage[]
}

model ProviderProfile {
  id                 String    @id @default(uuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id])
  businessName       String
  bio                String?
  city               String
  category           String
  rating             Float     @default(0)
  isOnline           Boolean   @default(false)
  verificationStatus String    @default("PENDING") // PENDING, APPROVED, REJECTED
  balance            Float     @default(0)
  
  services           Service[]
  availability       AvailabilitySlot[]
  bookings           Booking[] @relation("ProviderBookings")
  withdrawals        Withdrawal[]
}

model Service {
  id            String          @id @default(uuid())
  providerId    String
  provider      ProviderProfile @relation(fields: [providerId], references: [id])
  title         String
  description   String
  price         Float
  duration      Int             // Duration in minutes
  imageUrl      String?         
  isActive      Boolean         @default(true)
  bookings      Booking[]
}

model AvailabilitySlot {
  id            String          @id @default(uuid())
  providerId    String
  provider      ProviderProfile @relation(fields: [providerId], references: [id])
  day           String          // MONDAY, TUESDAY, etc.
  startTime     String          // HH:MM
  endTime       String          // HH:MM
}

model Booking {
  id             String          @id @default(uuid())
  clientId       String
  client         User            @relation("ClientBookings", fields: [clientId], references: [id])
  providerId     String
  provider       ProviderProfile @relation("ProviderBookings", fields: [providerId], references: [id])
  serviceId      String
  service        Service         @relation(fields: [serviceId], references: [id])
  date           DateTime
  status         String          @default("PENDING") // PENDING, PAID, ACCEPTED, SCHEDULED, COMPLETED, DISPUTED, CANCELLED, REFUNDED, REJECTED
  totalAmount    Float
  platformFee    Float
  providerAmount Float
  completionPin  String?         
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  transactions   Transaction[]
  review         Review?
  dispute        Dispute?
}

model Transaction {
  id          String   @id @default(uuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id])
  type        String   // PAYMENT, PAYOUT, REFUND, PLATFORM_FEE
  amount      Float
  createdAt   DateTime @default(now())
}

model Review {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  booking     Booking  @relation(fields: [bookingId], references: [id])
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())
}

model Dispute {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  booking     Booking  @relation(fields: [bookingId], references: [id])
  reason      String
  status      String   @default("OPEN") // OPEN, RESOLVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model SupportConversation {
  id          String           @id @default(uuid())
  createdAt   DateTime         @default(now())
  messages    SupportMessage[]
}

model SupportMessage {
  id             String              @id @default(uuid())
  conversationId String
  conversation   SupportConversation  @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User                @relation(fields: [senderId], references: [id])
  content        String
  createdAt      DateTime            @default(now())
}

model Withdrawal {
  id           String          @id @default(uuid())
  providerId   String
  provider     ProviderProfile @relation(fields: [providerId], references: [id])
  amount       Float
  status       String          @default("PENDING") // PENDING, APPROVED, REJECTED
  bankDetails  String?         
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}
